# Compass — environment variables template.
# Copy to .env and adjust as needed. .env is gitignored.

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB=compass
MONGO_COLLECTION=jobs
MONGO_COLLECTION_PROCESSED=jobs_processed

# --- MinIO (object storage) ---
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio12345
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio12345
MINIO_BUCKET_LANDING=compass-landing
MINIO_BUCKET_PROCESSED=compass-processed
MINIO_SECURE=false

# --- Scraping behavior ---
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
DOWNLOAD_DELAY=1
CONCURRENT_REQUESTS_PER_DOMAIN=1

# --- Logging ---
LOG_LEVEL=INFO
